# AgentHQ Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# GitHub Token (for GitHub Models - FREE)
# Create at https://github.com/settings/tokens (needs 'repo' scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (default: openai/gpt-4o)
# Available models on GitHub:
#   openai/gpt-4o         (recommended - fast, excellent quality)
#   openai/gpt-4-turbo    (powerful)
#   claude-3.5-sonnet     (excellent)
#   meta-llama/llama-3.1-405b (fast, very capable)
CLAUDE_MODEL=openai/gpt-4o

# Server port (optional)
# PORT=3000
